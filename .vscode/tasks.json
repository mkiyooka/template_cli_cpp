{
    "version": "2.0.0",
    "options": {
        "cwd": "${workspaceFolder}"
    },
    "tasks": [
        {
            "label": "config (Release)",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "config"],
            "group": { "kind": "build", "isDefault": false },
            "detail": "CMake 設定（Release）",
            "problemMatcher": []
        },
        {
            "label": "config (Debug)",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "config-debug"],
            "group": { "kind": "build", "isDefault": false },
            "detail": "CMake 設定（Debug）",
            "problemMatcher": []
        },
        {
            "label": "build",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "build"],
            "group": { "kind": "build", "isDefault": true },
            "detail": "ビルド（build/）",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "test",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "test"],
            "group": { "kind": "test", "isDefault": true },
            "detail": "ctest でテスト実行",
            "problemMatcher": []
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "clean"],
            "group": "build",
            "detail": "ビルド成果物をクリーン",
            "problemMatcher": []
        },
        {
            "label": "format",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "format"],
            "group": "build",
            "detail": "clang-format でコード整形",
            "problemMatcher": []
        },
        {
            "label": "lint",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "lint"],
            "group": "build",
            "detail": "clang-tidy で静的解析",
            "problemMatcher": []
        },
        {
            "label": "cppcheck",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "run-cppcheck"],
            "group": "build",
            "detail": "cppcheck で静的解析",
            "problemMatcher": []
        },
        {
            "label": "fullcheck",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "fullcheck"],
            "group": "build",
            "detail": "typos + lint + cppcheck をまとめて実行",
            "problemMatcher": []
        },
        {
            "label": "asan (config + build + test)",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "asan"],
            "group": "test",
            "detail": "ASan + UBSan ビルドとテスト（build-asan/）",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "coverage (config + run + report)",
            "type": "shell",
            "command": "pixi",
            "args": ["run", "coverage"],
            "group": "test",
            "detail": "カバレッジ計測・HTML レポート生成（build-coverage/）",
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "buildPreset",
            "description": "ビルドプリセットを選択",
            "type": "pickString",
            "options": ["release", "debug", "relwithdebinfo", "asan"],
            "default": "release"
        }
    ]
}
